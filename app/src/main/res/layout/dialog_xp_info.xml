<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="How XP is earned"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#1C1C1E"
        android:layout_marginBottom="16dp" />

    <!-- Table -->
    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stretchColumns="0">

        <!-- Header row -->
        <TableRow android:layout_width="match_parent">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Action"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#6E6E73"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:paddingBottom="6dp" />
            <TextView
                android:layout_width="wrap_content"
                android:text="XP"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#6E6E73"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:paddingBottom="6dp"
                android:gravity="end" />
        </TableRow>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E5E5EA"
            android:layout_marginBottom="8dp" />

        <!-- Row 1 -->
        <TableRow android:layout_width="match_parent" android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Clean day (no phubbing)"
                android:textSize="13sp"
                android:textColor="#1C1C1E"
                android:paddingEnd="12dp" />
            <TextView
                android:layout_width="wrap_content"
                android:text="+50"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#FF6A2E"
                android:gravity="end" />
        </TableRow>

        <!-- Row 2 -->
        <TableRow android:layout_width="match_parent" android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Avg risk below 20%"
                android:textSize="13sp"
                android:textColor="#1C1C1E"
                android:paddingEnd="12dp" />
            <TextView
                android:layout_width="wrap_content"
                android:text="+20"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#FF6A2E"
                android:gravity="end" />
        </TableRow>

        <!-- Row 3 -->
        <TableRow android:layout_width="match_parent" android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Under 30 phone unlocks"
                android:textSize="13sp"
                android:textColor="#1C1C1E"
                android:paddingEnd="12dp" />
            <TextView
                android:layout_width="wrap_content"
                android:text="+15"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#FF6A2E"
                android:gravity="end" />
        </TableRow>

        <!-- Row 4 -->
        <TableRow android:layout_width="match_parent" android:layout_marginBottom="14dp">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Social session, no phubbing"
                android:textSize="13sp"
                android:textColor="#1C1C1E"
                android:paddingEnd="12dp" />
            <TextView
                android:layout_width="wrap_content"
                android:text="+30"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#FF6A2E"
                android:gravity="end" />
        </TableRow>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E5E5EA"
            android:layout_marginBottom="10dp" />

        <!-- Multiplier header -->
        <TableRow android:layout_width="match_parent" android:layout_marginBottom="6dp">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Streak Bonus"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#6E6E73"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:paddingBottom="6dp" />
            <TextView
                android:layout_width="wrap_content"
                android:text="Multiplier"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#6E6E73"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:paddingBottom="6dp"
                android:gravity="end" />
        </TableRow>

        <!-- Streak row 1 -->
        <TableRow android:layout_width="match_parent" android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="7-day streak  (+100 XP bonus)"
                android:textSize="13sp"
                android:textColor="#1C1C1E"
                android:paddingEnd="12dp" />
            <TextView
                android:layout_width="wrap_content"
                android:text="x1.5"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#FF6A2E"
                android:gravity="end" />
        </TableRow>

        <!-- Streak row 2 -->
        <TableRow android:layout_width="match_parent">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="30-day streak  (+500 XP bonus)"
                android:textSize="13sp"
                android:textColor="#1C1C1E"
                android:paddingEnd="12dp" />
            <TextView
                android:layout_width="wrap_content"
                android:text="x2.0"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#FF6A2E"
                android:gravity="end" />
        </TableRow>

    </TableLayout>

</LinearLayout>
